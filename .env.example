# Copy this file to `.env` and fill in your Supabase project values.
# Find these in Supabase → Project Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Paystack — public key only. Find at https://dashboard.paystack.com/#/settings/developers
# Use pk_test_... for testing, pk_live_... for production.
# NEVER put the secret key here — it must remain server-side only.
VITE_PAYSTACK_PUBLIC_KEY=
